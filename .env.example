# Supabase project — required for waitlist signup
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Server-only — DO NOT prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public anon/publishable key — safe for the browser.
# Used by: static rank-lookup form, vendor portal auth (vendorBrowserClient / vendorServerClient).
# This is NOT the service-role key; it cannot bypass RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optional: Vercel KV / Upstash credentials for per-IP rate limiting on /api/join
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Admin dashboard — /admin/* routes
# Password for signing into the event-review dashboard.
ADMIN_DASHBOARD_PASSWORD=change-me-before-deploying
# Secret used to sign the HMAC-SHA256 bearer token stored in the pack_admin cookie.
# Generate with: openssl rand -hex 32
ADMIN_COOKIE_SECRET=change-me-before-deploying

# Canonical site URL (used for absolute redirects, e.g. logout route)
# NEXT_PUBLIC_SITE_URL=https://trypack.app
