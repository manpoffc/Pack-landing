# Supabase project — required for waitlist signup
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Server-only — DO NOT prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public anon key (used by the static rank-lookup form)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optional: Vercel KV / Upstash credentials for per-IP rate limiting on /api/join
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
